{
	"name": "pratul-portfolio-website",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "next build",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write .",
		"db:migrate": "wrangler d1 migrations apply portfolio-contact-book --local",
		"db:migrate:remote": "wrangler d1 migrations apply portfolio-contact-book --remote",
		"deploy": "next build && wrangler deploy",
		"deploy:pages": "next build && wrangler pages deploy out --project-name=pratul-portfolio",
		"dev": "next dev --turbo",
		"pretest": "next build",
		"preview": "next build && wrangler dev",
		"preview:pages": "next build && wrangler pages dev out --port 8789",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json"
	},
	"dependencies": {
		"geist": "^1.3.1",
		"next": "^15.2.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@cloudflare/workers-types": "^4.20260702.1",
		"@tailwindcss/postcss": "^4.0.15",
		"@types/node": "^22.20.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"postcss": "^8.5.3",
		"tailwindcss": "^4.0.15",
		"typescript": "^5.8.2",
		"vitest": "^4.1.9",
		"wrangler": "^4.20.0"
	},
	"packageManager": "npm@11.6.1"
}
